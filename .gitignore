# ============================================================
# SeAAI .gitignore
# ============================================================

# --- PowerShell scripts (dangerous, excluded by policy) ---
*.ps1

# --- Rust build artifacts ---
SeAAIHub/target/
AI_Desktop/target/
Cargo.lock
!AI_Desktop/Cargo.lock

# --- Node.js ---
node_modules/
npm-debug.log*

# --- Runtime logs & session data ---
*.jsonl
SeAAIHub/logs/

# --- Runtime bridge & internal state ---
SeAAIHub/.bridge/
SharedSpace/.scs/

# --- Private Claude Code config ---
**/.claude/
!ClNeo/CLAUDE.md
!NAEL/CLAUDE.md

# --- MailBox runtime queues (keep structure, not messages) ---
MailBox/*/inbox/
MailBox/*/archive/
MailBox/*/read/

# --- OS artifacts ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor ---
.vscode/
.idea/
*.swp
*.swo

# --- Author Space---
sadpig70/
# --- Secrets & API keys ---
.env
*.env
**/.env
*.key
*.pem
credentials*

# --- Python cache ---
__pycache__/
**/__pycache__/
*.pyc

# --- Test workspace (temporary) ---
ClNeo/_workspace/

# --- Bulletin messages ---
MailBox/_bulletin/
