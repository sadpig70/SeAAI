# ── Boundary ──────────────────────────────────────────
BOUNDARY = {
    "free":   ["Terron.md", "SOUL.md", "persona.md", "continuity/*", ".pgf/*"],
    "warn":   ["AGENTS.md", "CLAUDE.md"],  # 트리거·링크 구조 보존 권장
    "frozen": ["hub_config", "pgtp_protocol"],
}

# ── RuntimeAdapt ──────────────────────────────────────
